# Гид Новосёла — переменные окружения
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# ── Web3Forms ──────────────────────────────────────────────────────
# Ключ для отправки писем при активации сертификата и кнопке "Написать"
# Зарегистрируйтесь на https://web3forms.com и получите ключ
# Сейчас прописан напрямую в src/components/Certificate.jsx
WEB3FORMS_KEY=

# ── FTP-деплой (SprintHost) ────────────────────────────────────────
# Используется в deploy.sh и в deploy-ftp.js
# ВНИМАНИЕ: deploy-ftp.js сейчас содержит значения напрямую в коде —
# перенесите их сюда и читайте через process.env
FTP_HOST=
FTP_USER=
FTP_PASS=
FTP_PATH=/public_html

# ── PHP send-lead.php ──────────────────────────────────────────────
# Email-адрес, который используется как from в письмах партнёрам
# Настраивается прямо в public/send-lead.php, а не через env
# ADMIN_EMAIL=no-reply@gidnovosela.ru
